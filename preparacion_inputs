# Listado de especies con nombre taxonómico válido
```{r}

# Leer checklist CONABIO
mamiferos <- read.csv("C:/Users/Ale/Desktop/rdir/doct_cap1/preparacion_inputs/mamiferos_mx_conabio.csv")

# Filtrar solo especies aceptadas
spp_validas <- mamiferos %>%
  filter(
    taxonomicStatus == "accepted",
    taxonRank == "species"
  ) %>%
  mutate(
    species = paste(genus, specificEpithet)
  ) %>%
  pull(species) %>%
  unique() # listado con 614 spp válidas

```
