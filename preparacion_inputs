```{r}
getwd()
df_mammals613 <- occ_download_import(as.download("0043814-260409193756587.zip"))

#unique(df_gbif$issue) # Para ver los problemas de los datos descargados

library(dplyr)
library(stringr)

head(df_mammals613)


df_clean <- df_mammals613 %>%
  filter(
    # Coordenadas válidas
    !is.na(decimalLongitude),
    !is.na(decimalLatitude),
    
    # Presencia
    occurrenceStatus == "PRESENT",
    
    # Incertidumbre
    is.na(coordinateUncertaintyInMeters) |
      coordinateUncertaintyInMeters <= 15000,
    
    # Tipo de dato
    basisOfRecord %in% c(
      "HUMAN_OBSERVATION",
      "OBSERVATION",
      "PRESERVED_SPECIMEN"
    ),
    
    # Issues críticos
    is.na(issue) |
      !str_detect(issue,
        "ZERO_COORDINATE|COUNTRY_COORDINATE_MISMATCH|COORDINATE_OUT_OF_RANGE|INVALID_COORDINATE"
      ),
    
    # Coordenadas inválidas
    decimalLatitude != 0,
    decimalLongitude != 0,
    
    # Fecha válida
    !is.na(eventDate)
  )

# Limpieza adicional con CoordinateCleaner

library(CoordinateCleaner)

df_clean2 <- clean_coordinates(
  x = df_clean,
  lon = "decimalLongitude",
  lat = "decimalLatitude",
  species = "species",
  tests = c("capitals", "centroids", "institutions", "zeros")
)

```


